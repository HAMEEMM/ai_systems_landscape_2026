# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
# .env is listed in .gitignore — it will NEVER be committed to git.
# ─────────────────────────────────────────────────────────────────────

# ── Foundation Model APIs (Layer 1 of the 8-layer stack) ─────────────

OPENAI_API_KEY=sk-00000000000000000
ANTHROPIC_API_KEY=sk-00000000000000000
GOOGLE_API_KEY=sk-00000000000000000

# ── Observability (Layer 8) ───────────────────────────────────────────
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=agentic-ai-ppas
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Tool Integration (Layer 4) ────────────────────────────────────────
TAVILY_API_KEY=your-tavily-key-here

# ── Memory Systems (Layer 3) ─────────────────────────────────────────
MEM0_API_KEY=your-mem0-key-here
REDIS_URL=redis://localhost:6379
