# ─────────────────────────────────────────────────────────────────────────
# Environment variables — copy this file to .env and fill in your values
# cp shared/config/.env.example shared/config/.env
# ─────────────────────────────────────────────────────────────────────────

# OpenAI API key (used by Phase 4 NL2SQL examples)
OPENAI_API_KEY=sk-...

# Optional: Anthropic / Google (Phase 4 LLM alternatives)
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Optional: LangSmith tracing (Phase 5 observability)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=analytical-ai-dev

# Data paths (relative to dev/)
# DATA_DIR=../data
# RESULTS_DIR=phase-5-experiments/01-benchmark-results
