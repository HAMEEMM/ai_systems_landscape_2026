%% references.bib
%% BibTeX database for: A Unified Taxonomy of 19 AI System Types
%% engrXiv preprint version — uses plainnat style via natbib
%%
%% HOW THIS WORKS:
%% ───────────────
%% Instead of writing references inline in the .tex file using
%% \begin{thebibliography}...\end{thebibliography}, this .bib file
%% stores every reference as a structured BibTeX entry.
%%
%% In the .tex file, you simply write:
%%   \bibliography{references}
%% (no .bib extension needed). The engrxiv-paper.tex file sets
%% \bibliographystyle{plainnat} for natbib-compatible formatting.
%%
%% When you compile, run these commands in order:
%%   1. pdflatex engrxiv-paper.tex     (first pass — collects \cite keys)
%%   2. bibtex engrxiv-paper           (reads .bib, generates .bbl)
%%   3. pdflatex engrxiv-paper.tex     (inserts bibliography)
%%   4. pdflatex engrxiv-paper.tex     (resolves cross-references)
%%
%% BENEFITS:
%%   • Clean numeric citation formatting via plainnat
%%   • Easy to add/remove references without touching the .tex
%%   • Reusable across papers
%%   • Consistent formatting guaranteed by BibTeX style
%% ═══════════════════════════════════════════════════════════════════

